# Copy to config.env and adjust for your cluster.
# cp config.env.example config.env

MONITORING_NAMESPACE=monitoring
TRAEFIK_NAMESPACE=traefik
ROBOSHOP_NAMESPACE=default

# kube-prometheus-stack Helm release name (used for Grafana secret lookup)
GRAFANA_RELEASE=kube-prometheus-stack
GRAFANA_SECRET=kube-prometheus-stack-grafana
GRAFANA_SERVICE=kube-prometheus-stack-grafana

# Prometheus datasource UID inside Grafana (default for kube-prometheus-stack)
PROMETHEUS_DS_UID=prometheus

# Grafana folder for dashboards
GRAFANA_FOLDER_UID=roboshop-obs
GRAFANA_FOLDER_TITLE=Roboshop Observability

# Leave empty to read password from the Kubernetes secret at deploy time
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# Leave empty to auto port-forward Grafana during deploy
# Or set to your ingress URL, e.g. https://grafana-dev.example.com
GRAFANA_URL=

# Seconds to wait for Traefik metrics to appear in Prometheus
WAIT_FOR_TRAEFIK_METRICS=120

# Alert thresholds (deployed via grafana/deploy_alerts.py)
ALERT_CPU_LIMIT_PCT=85
ALERT_MEM_LIMIT_PCT=85
ALERT_LATENCY_P95_SEC=2
ALERT_ERROR_RATE_MIN=0.001
ALERT_RULE_INTERVAL=60

# Email alerts — AWS SES SMTP credentials (never commit real values; keep in config.env only)
# SES SMTP user/password: IAM → SES → SMTP settings (not the same as AWS access keys)
GRAFANA_SMTP_HOST=email-smtp.us-east-1.amazonaws.com:587
GRAFANA_SMTP_USER=
GRAFANA_SMTP_PASSWORD=
GRAFANA_SMTP_FROM=raghudevops88@gmail.com
GRAFANA_SMTP_FROM_NAME=Roboshop Observability
GRAFANA_ALERT_EMAIL=raghudevops88@gmail.com
GRAFANA_DEPLOYMENT=kube-prometheus-stack-grafana
# Main Grafana server container (not grafana-sc-dashboard sidecar)
GRAFANA_CONTAINER=grafana
